{
  "name": "vlocity-arena-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply vlocity-arena-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply vlocity-arena-db --remote",
    "db:seed": "wrangler d1 execute vlocity-arena-db --local --file=./seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.16",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^25.0.3",
    "drizzle-kit": "^0.31.8",
    "wrangler": "^4.54.0"
  }
}
